APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_ES

# SEO / structured data (JSON-LD + Open Graph) — all optional.
# Default OG image used when a page provides none. Path relative to public/ (asset()).
SEO_DEFAULT_IMAGE=images/og-default.png
# Organization name for JSON-LD. Leave empty to reuse APP_NAME (recommended; only set it if the legal/brand name differs).
SEO_ORG_NAME=
# Organization logo for JSON-LD. Path under public/, e.g. images/logo.png
SEO_ORG_LOGO=
# Social profiles for the JSON-LD "sameAs" array (full URLs).
SEO_ORG_LINKEDIN=
SEO_ORG_INSTAGRAM=
SEO_ORG_TWITTER=

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Mailgun — recommended for production (driver preinstalled; set these + MAIL_MAILER=mailgun)
MAILGUN_DOMAIN=
MAILGUN_SECRET=
MAILGUN_ENDPOINT=api.eu.mailgun.net

# Leads — where new form submissions are notified.
# Email recipient (leave empty to notify the first registered user / site owner).
LEAD_NOTIFY_EMAIL=
# Discord incoming webhook URL (leave empty to disable the Discord notification).
DISCORD_WEBHOOK_URL=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Google Tag Manager — when set, GTM loads (Consent Mode v2) and the cookie banner appears.
# Leave empty to disable all tracking and the cookie banner entirely.
GOOGLE_TAG_MANAGER_ID=
# Optional: URL to your cookie policy, shown as a link in the banner.
# If the URL contains a '#', wrap it in quotes so .env does not read it as a comment:
# COOKIE_POLICY_URL="https://example.com/legal#cookies"
COOKIE_POLICY_URL=
